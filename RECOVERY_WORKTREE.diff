-            {n.pnl_pct > 0 ? '+' : ''}{n.pnl_pct.toFixed(2)}%
-          </span>
-        )}
-      </div>
-
-      {/* Exit reason + leverage */}
-      {(isClose || n.leverage) && (
-        <div style={{ display: 'flex', alignItems: 'center', gap: 6, marginTop: 3 }}>
-          {isClose && n.exit_reason && (
-            <span style={{ fontSize: 9, color: 'var(--dim)', ...MONO }}>
-              {exitReasonLabel(n.exit_reason)}
-            </span>
