-          to   { opacity: 1; transform: translateX(0); }
-        }
-        @keyframes toastPulse {
-          0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--green); }
-          50%       { opacity: 0.5; box-shadow: 0 0 3px var(--green); }
-        }
-        @keyframes toastProgress {
-          from { width: 100%; }
-          to   { width: 0%; }
-        }
-      `}</style>
-
-      <div style={{
-        position: 'fixed',
-        top: 20,
-        right: 20,
-        zIndex: 950,
-        display: 'flex',
-        flexDirection: 'column',
-        alignItems: 'flex-end',
-        pointerEvents: 'none',
-      }}>
-        {toasts.map((t, idx) => (
